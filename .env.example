# Supabase Public Keys (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Supabase Admin/Private Keys (Required for migrations/backend only — never expose to browser)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Google Drive API Keys (comma-separated, rotated server-side — never exposed to browser)
GOOGLE_DRIVE_API_KEYS=AIzaSy...,AIzaSy...,AIzaSy...
